      "parameters": {
        "jsCode": "const lastLead = $input.first().json.Value;\n\nconst number = parseInt(lastLead.replace(\"L\", \"\"), 10);\n\nconst nextLeadId = \"L\" + String(number + 1).padStart(4, \"0\");\n\n// Original form submission\nconst form = $('Google Sheets Trigger').first().json;\n\nreturn [\n  {\n    json: {\n      ...form,\n      Lead_ID: nextLeadId\n    }\n  }\n];"
      },
