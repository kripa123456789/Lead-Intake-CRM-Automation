    {
      "parameters": {
        "jsCode": "const lead = $input.first().json;\n\n// Today's date\nconst followup = new Date();\n\n// Add 2 days\nfollowup.setDate(followup.getDate() + 2);\n\n// Format: YYYY-MM-DD\nconst followupDate = followup.toISOString().split(\"T\")[0];\n\nreturn [\n  {\n    json: {\n      ...lead,\n      Followup_Date: followupDate\n    }\n  }\n];"
      },
      "type": "n8n-nodes-base.code",
